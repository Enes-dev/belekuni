import subprocess
import sys

# Kütüphane yüklü mü kontrol et, değilse yükle
try:
    from argon2 import PasswordHasher
    from argon2.exceptions import VerifyMismatchError
except ImportError:
    print("Argon2 kütüphanesi eksik, şu an yükleniyor... Lütfen bekleyin.")
    subprocess.check_call([sys.executable, "-m", "pip", "install", "argon2-cffi"])
    from argon2 import PasswordHasher
    from argon2.exceptions import VerifyMismatchError
    print("Yükleme tamamlandı!\n")

# --- BURADAN SONRASI ESKİ KODUN ---

ph = PasswordHasher()

def kayit_ol(kullanici_adi, parola):
    hashli_parola = ph.hash(parola)
    print(f"\n[KAYIT] Kullanıcı: {kullanici_adi}")
    print(f"[HASH] Veritabanına kaydedilecek veri: {hashli_parola}")
    return hashli_parola

def giris_yap(kullanici_adi, girilen_parola, kaydedilmis_hash):
    try:
        ph.verify(kaydedilmis_hash, girilen_parola)
        print(f"\n[GİRİŞ] Kullanıcı '{kullanici_adi}' için giriş BAŞARILI!")
        return True
    except VerifyMismatchError:
        print(f"\n[HATA] Kullanıcı '{kullanici_adi}' için hatalı parola!")
        return False

# Demo Akışı
user_db = {}
p_hash = kayit_ol("Ahmet", "cok_gizli_123")
user_db["Ahmet"] = p_hash
giris_yap("Ahmet", "cok_gizli_123", user_db["Ahmet"])
